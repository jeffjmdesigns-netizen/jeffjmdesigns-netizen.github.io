/* ============================================
   PHILOSOPHIA SCRIPTS — Interactions & Reveals
   ============================================ */

document.addEventListener('DOMContentLoaded', () => {

    // ---- Navbar scroll effect ----
    const navbar = document.getElementById('navbar');
    const navbarLogo = document.getElementById('navbarLogo');
    let lastScroll = 0;

    const portalRings = document.querySelectorAll('.portal-ring');

    const handleScroll = () => {
        const scrollY = window.scrollY;

        // Navbar effect
        if (scrollY > 60) {
            navbar.classList.add('scrolled');
            if (navbarLogo) navbarLogo.src = 'imagery/primary-logo.png';
        } else {
            navbar.classList.remove('scrolled');
            if (navbarLogo) navbarLogo.src = 'imagery/primary-logo-reversed.png';
        }

        // Portal rings scroll drama
        portalRings.forEach((ring, index) => {
            const speed = (index + 1) * 0.15;
            const rotation = scrollY * speed;
            const scale = 1 + (scrollY * 0.0005);
            // Combine with existing translate(-50%, -50%) from CSS
            ring.style.transform = `translate(-50%, -50%) rotate(${rotation}deg) scale(${scale})`;
        });

        lastScroll = scrollY;
    };

    window.addEventListener('scroll', handleScroll, { passive: true });

    // ---- Mobile nav toggle ----
    const navToggle = document.getElementById('navToggle');
    const navLinks = document.getElementById('navLinks');

    navToggle.addEventListener('click', () => {
        navToggle.classList.toggle('active');
        navLinks.classList.toggle('open');
    });

    // Close mobile nav on link click
    navLinks.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
            navToggle.classList.remove('active');
            navLinks.classList.remove('open');
        });
    });

    // ---- Intersection Observer — Scroll Reveals ----
    const revealElements = document.querySelectorAll('.reveal');

    const revealObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    revealObserver.unobserve(entry.target);
                }
            });
        },
        { threshold: 0.15, rootMargin: '0px 0px -50px 0px' }
    );

    revealElements.forEach(el => revealObserver.observe(el));

    // ---- Script Cards — Staggered Reveal ----
    const scriptCards = document.querySelectorAll('.script-card');

    const cardObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const delay = parseInt(entry.target.dataset.delay) || 0;
                    setTimeout(() => {
                        entry.target.classList.add('visible');
                    }, delay);
                    cardObserver.unobserve(entry.target);
                }
            });
        },
        { threshold: 0.1, rootMargin: '0px 0px -30px 0px' }
    );

    scriptCards.forEach(card => cardObserver.observe(card));

    // ---- Scroll Spy — Active Section Tracking ----
    const sections = ['about', 'projects', 'contact'].map(id => document.getElementById(id));
    const navItems = document.querySelectorAll('.navbar__links a');

    const scrollSpyObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const id = entry.target.getAttribute('id');
                    
                    navItems.forEach(link => {
                        link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
                    });
                }
            });
        },
        // Threshold: 0.5 means when 50% of the section is visible
        { threshold: 0.5, rootMargin: '-10% 0px -40% 0px' }
    );

    sections.forEach(section => {
        if (section) scrollSpyObserver.observe(section);
    });


    // ---- Smooth scroll for anchor links ----
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
            const href = anchor.getAttribute('href');
            if (href === '#') return;
            e.preventDefault();
            const target = document.querySelector(href);
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    });

    // ---- Parallax on portal rings (subtle) ----
    const portal = document.querySelector('.hero__portal');

    if (portal && window.matchMedia('(min-width: 768px)').matches) {
        window.addEventListener('mousemove', (e) => {
            const x = (e.clientX / window.innerWidth - 0.5) * 12;
            const y = (e.clientY / window.innerHeight - 0.5) * 12;
            portal.style.transform = `translate(calc(-50% + ${x}px), calc(-50% + ${y}px))`;
        }, { passive: true });
    }

});

/* ============================================
   PHILOSOPHIA SCRIPTS — Design System & Styles
   ============================================ */

@import url('https://fonts.googleapis.com/css2?family=Geologica:wght@300;400;500;600;700;800&display=swap');

/* --- Design Tokens --- */
:root {
    /* Primary Palette */
    --vision: #E85C49;
    --shadow: #1C2833;
    --light: #FAFBFC;
    --silhouette: #384755;

    /* Secondary / Accent */
    --insight: #17A7AA;
    --genius: #B3C66D;
    --energy: #E5BD6E;
    --flair: #E87654;

    /* Typography */
    --font-primary: 'Geologica', sans-serif;

    /* Spacing */
    --space-xs: 0.5rem;
    --space-sm: 1rem;
    --space-md: 2rem;
    --space-lg: 4rem;
    --space-xl: 6rem;
    --space-2xl: 8rem;

    /* Transitions */
    --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);
    --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
    --duration-fast: 200ms;
    --duration-base: 350ms;
    --duration-slow: 600ms;
}

/* --- Reset & Base --- */
*,
*::before,
*::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

body {
    font-family: var(--font-primary);
    font-weight: 300;
    color: var(--shadow);
    background-color: var(--light);
    line-height: 1.7;
    overflow-x: hidden;
}

h1,
h2,
h3,
h4,
h5,
h6 {
    font-weight: 700;
    line-height: 1.2;
}

a {
    text-decoration: none;
    color: inherit;
}

img {
    max-width: 100%;
    display: block;
}

button {
    font-family: var(--font-primary);
    cursor: pointer;
    border: none;
    outline: none;
}

/* --- Utility --- */
.container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-md);
}

.sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
}

/* ============================================
   NAVIGATION
   ============================================ */
.navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1.5rem 0;
    transition: background var(--duration-base) var(--ease-smooth),
        backdrop-filter var(--duration-base) var(--ease-smooth);
}

.navbar.scrolled {
    background: rgba(250, 251, 252, 0.85);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(28, 40, 51, 0.08);
    box-shadow: 0 1px 12px rgba(28, 40, 51, 0.06);
}

.navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-md);
}

.navbar__logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.navbar__logo-img {
    height: 42px;
    width: auto;
    display: block;
}



.navbar__links {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    list-style: none;
}

.navbar__links a {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(250, 251, 252, 0.75);
    transition: color var(--duration-fast) var(--ease-smooth);
    position: relative;
}

.navbar.scrolled .navbar__links a {
    color: rgba(28, 40, 51, 0.55);
}

.navbar__links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--vision);
    transition: width var(--duration-base) var(--ease-smooth);
}

.navbar.scrolled .navbar__links a:hover {
    color: var(--shadow);
}

/* Active State / Scroll Spy */
.navbar__links a.active {
    color: var(--light);
}

.navbar.scrolled .navbar__links a.active {
    color: var(--shadow);
}

.navbar__links a:hover::after,
.navbar__links a.active::after {
    width: 100%;
}

/* Mobile toggle */
.navbar__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    padding: 4px;
}

.navbar__toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--light);
    border-radius: 2px;
    transition: transform var(--duration-base) var(--ease-smooth),
        opacity var(--duration-fast) var(--ease-smooth),
        background var(--duration-base) var(--ease-smooth);
}

.navbar.scrolled .navbar__toggle span {
    background: var(--shadow);
}

.navbar__toggle.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
}

.navbar__toggle.active span:nth-child(2) {
    opacity: 0;
}

.navbar__toggle.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
}

@media (max-width: 768px) {
    .navbar__toggle {
        display: flex;
    }

    .navbar__links {
        position: fixed;
        top: 0;
        right: 0;
        width: 280px;
        height: 100vh;
        flex-direction: column;
        justify-content: center;
        gap: var(--space-lg);
        background: rgba(250, 251, 252, 0.97);
        backdrop-filter: blur(30px);
        transform: translateX(100%);
        transition: transform var(--duration-slow) var(--ease-smooth);
    }

    .navbar__links.open {
        transform: translateX(0);
    }

    .navbar__links a {
        font-size: 1.1rem;
    }
}

/* ============================================
   HERO — "THE THRESHOLD"
   ============================================ */
.hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--shadow);
}

/* Hero background image */
.hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
}

/* Background gradients removed for video clarity */
.hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
}

/* Geometric background grid */
.hero__grid {
    position: absolute;
    inset: 0;
    z-index: 3;
    opacity: 0.04;
    background-image:
        linear-gradient(rgba(250, 251, 252, 0.3) 1px, transparent 1px),
        linear-gradient(90deg, rgba(250, 251, 252, 0.3) 1px, transparent 1px);
    background-size: 60px 60px;
}

/* Portal Container */
/* Dramatized Portal Rings */
.hero__portal {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    pointer-events: auto;
    /* Allow hover on portal area */
    z-index: 3;
    cursor: crosshair;
}

.portal-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.8s var(--ease-smooth);
    will-change: transform, border-color, width, height;
}

.portal-ring--1 {
    width: 400px;
    height: 400px;
    border-color: rgba(232, 92, 73, 0.2);
    animation: portalSpin 25s linear infinite;
}

.portal-ring--2 {
    width: 320px;
    height: 320px;
    border-color: rgba(23, 167, 170, 0.15);
    animation: portalSpinReverse 18s linear infinite;
}

.portal-ring--3 {
    width: 240px;
    height: 240px;
    border-color: rgba(179, 198, 109, 0.12);
    animation: portalSpin 12s linear infinite;
}

.portal-ring--4 {
    width: 180px;
    height: 180px;
    border-color: rgba(255, 255, 255, 0.08);
    animation: portalSpinReverse 30s linear infinite;
}

/* Hover Drama */
.hero__portal:hover .portal-ring {
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow: 0 0 30px rgba(232, 92, 73, 0.1);
}

.hero__portal:hover .portal-ring--1 {
    width: 450px;
    height: 450px;
    animation-duration: 10s;
    border-color: rgba(232, 92, 73, 0.5);
}

.hero__portal:hover .portal-ring--2 {
    width: 380px;
    height: 380px;
    animation-duration: 8s;
    border-color: rgba(23, 167, 170, 0.4);
}

.hero__portal:hover .portal-ring--3 {
    width: 300px;
    height: 300px;
    animation-duration: 5s;
    border-color: rgba(179, 198, 109, 0.3);
}

.hero__portal:hover .portal-ring--4 {
    width: 220px;
    height: 220px;
    animation-duration: 12s;
    border-color: rgba(255, 255, 255, 0.2);
}

/* Geometric decorations on rings */
.portal-ring::before,
.portal-ring::after {
    content: '';
    position: absolute;
    background: currentColor;
}

.portal-ring--1::before {
    width: 8px;
    height: 8px;
    top: 0;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    color: var(--vision);
    opacity: 0.6;
}

.portal-ring--2::after {
    width: 6px;
    height: 6px;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 50%;
    color: var(--insight);
    opacity: 0.5;
}

.portal-ring--3::before {
    width: 12px;
    height: 2px;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    color: var(--genius);
    opacity: 0.4;
}


/* Greek column decorations */
.hero__column {
    position: absolute;
    width: 3px;
    opacity: 0.08;
    background: linear-gradient(to bottom, transparent, var(--light), transparent);
    z-index: 4;
}

.hero__column--left {
    left: 8%;
    top: 10%;
    height: 80%;
    animation: columnReveal 1.5s ease-out 0.5s both;
}

.hero__column--right {
    right: 8%;
    top: 15%;
    height: 70%;
    animation: columnReveal 1.5s ease-out 0.8s both;
}

.hero__column::before,
.hero__column::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 3px;
    background: var(--light);
    opacity: 0.5;
}

.hero__column::before {
    top: 0;
}

.hero__column::after {
    bottom: 0;
}

/* Hero Content */
.hero__content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 780px;
    padding: 0 var(--space-md);
}

.hero__tagline {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--vision);
    margin-bottom: var(--space-md);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeSlideUp 0.8s var(--ease-smooth) 0.3s forwards;
}

.hero__title {
    font-size: clamp(2.4rem, 5.5vw, 4.2rem);
    font-weight: 700;
    color: var(--light);
    margin-bottom: var(--space-md);
    opacity: 0;
    transform: translateY(30px);
    animation: fadeSlideUp 0.9s var(--ease-smooth) 0.5s forwards;
    line-height: 1.15;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
}

.hero__title em {
    font-style: normal;
    background: linear-gradient(135deg, var(--vision), var(--flair));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 300;
    color: var(--light);
    max-width: 560px;
    margin: 0 auto var(--space-lg);
    opacity: 0;
    transform: translateY(30px);
    animation: fadeSlideUp 0.9s var(--ease-smooth) 0.7s forwards;
    line-height: 1.8;
}

.hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    background: var(--vision);
    color: var(--light);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 4px;
    transition: transform var(--duration-base) var(--ease-spring),
        box-shadow var(--duration-base) var(--ease-smooth),
        background var(--duration-base) var(--ease-smooth);
    opacity: 0;
    transform: translateY(30px);
    animation: fadeSlideUp 0.9s var(--ease-smooth) 0.9s forwards;
    position: relative;
    overflow: hidden;
}

.hero__cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 40%, rgba(255, 255, 255, 0.1));
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-smooth);
}

.hero__cta:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 30px rgba(232, 92, 73, 0.35);
}

.hero__cta:hover::before {
    opacity: 1;
}

.hero__cta-arrow {
    transition: transform var(--duration-base) var(--ease-spring);
}

.hero__cta:hover .hero__cta-arrow {
    transform: translateX(4px);
}

/* Scroll indicator */
.hero__scroll {
    position: absolute;
    bottom: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeIn 1s var(--ease-smooth) 1.5s forwards;
    z-index: 10;
}

.hero__scroll-text {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--light);
    font-weight: 500;
    opacity: 0.7;
}

.hero__scroll-mouse {
    width: 26px;
    height: 46px;
    border-radius: 100px;
    background: #1C2833;
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    display: flex;
    justify-content: center;
    padding-top: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
}

.hero__scroll-dot {
    width: 10px;
    height: 10px;
    background: var(--vision);
    border-radius: 50%;
    z-index: 2;
    animation: mouseScroll 2s cubic-bezier(0.45, 0.05, 0.55, 0.95) infinite;
}

.hero__scroll-mouse::after {
    content: '';
    position: absolute;
    top: 22px;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.15) 1px, transparent 1px);
    background-size: 2px 6px;
    background-repeat: repeat-y;
}

@keyframes mouseScroll {
    0% {
        transform: translateY(0);
        opacity: 1;
        box-shadow: 0 0 0 rgba(232, 92, 73, 0);
    }

    50% {
        transform: translateY(12px);
        opacity: 0.8;
        box-shadow: 0 0 10px rgba(232, 92, 73, 0.4);
    }

    100% {
        transform: translateY(0);
        opacity: 1;
        box-shadow: 0 0 0 rgba(232, 92, 73, 0);
    }
}

/* ============================================
   SCRIPT LIBRARY
   ============================================ */
.scripts {
    position: relative;
    padding: var(--space-2xl) 0;
    background: #F0F2F5;
}

.scripts__header {
    text-align: center;
    margin-bottom: var(--space-xl);
}

.scripts__label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--insight);
    margin-bottom: var(--space-sm);
}

.scripts__title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--shadow);
    margin-bottom: var(--space-sm);
}

.scripts__subtitle {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--silhouette);
    max-width: 520px;
    margin: 0 auto;
}

/* Card Grid */
.scripts__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
}

.script-card {
    position: relative;
    background: #FFFFFF;
    border: 1px solid rgba(28, 40, 51, 0.08);
    border-radius: 8px;
    padding: var(--space-lg) var(--space-md);
    transition: transform var(--duration-base) var(--ease-spring),
        border-color var(--duration-base) var(--ease-smooth),
        box-shadow var(--duration-base) var(--ease-smooth);
    overflow: hidden;
    opacity: 0;
    transform: translateY(40px);
}

.script-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s var(--ease-smooth),
        transform 0.6s var(--ease-smooth),
        border-color var(--duration-base) var(--ease-smooth),
        box-shadow var(--duration-base) var(--ease-smooth);
}

.script-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--vision), var(--flair));
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-smooth);
}

.script-card:hover {
    transform: translateY(-6px);
    border-color: rgba(232, 92, 73, 0.25);
    box-shadow: 0 16px 50px rgba(28, 40, 51, 0.08);
}

.script-card:hover::before {
    opacity: 1;
}

.script-card__icon {
    width: 56px;
    height: 56px;
    margin-bottom: var(--space-md);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
}

.script-card__icon--film {
    background: rgba(232, 92, 73, 0.1);
    color: var(--vision);
}

.script-card__icon--tv {
    background: rgba(23, 167, 170, 0.1);
    color: var(--insight);
}

.script-card__icon--theater {
    background: rgba(229, 189, 110, 0.1);
    color: var(--energy);
}

.script-card__icon svg {
    width: 28px;
    height: 28px;
}

.script-card__category {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--silhouette);
    margin-bottom: var(--space-xs);
}

.script-card__title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--shadow);
    margin-bottom: var(--space-sm);
}

.script-card__desc {
    font-size: 0.92rem;
    font-weight: 300;
    color: var(--silhouette);
    line-height: 1.7;
    margin-bottom: var(--space-md);
}

.script-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.script-card__tag {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding: 0.3rem 0.8rem;
    border-radius: 100px;
    border: 1px solid rgba(28, 40, 51, 0.12);
    color: var(--silhouette);
    transition: border-color var(--duration-fast) var(--ease-smooth),
        color var(--duration-fast) var(--ease-smooth);
}

.script-card:hover .script-card__tag {
    border-color: rgba(232, 92, 73, 0.25);
    color: var(--shadow);
}

@media (max-width: 1024px) {
    .scripts__grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 640px) {
    .scripts__grid {
        grid-template-columns: 1fr;
    }
}

/* ============================================
   THE PROVOCATEUR
   ============================================ */
.provocateur {
    position: relative;
    padding: var(--space-2xl) 0;
    overflow: hidden;
    min-height: 60vh;
    display: flex;
    align-items: center;
}

/* Geometric pattern background */
.provocateur__pattern {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image: url("data:image/svg+xml,%3Csvg width='80' height='80' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M40 0L80 40L40 80L0 40Z' fill='none' stroke='%231C2833' stroke-width='0.5'/%3E%3Ccircle cx='40' cy='40' r='15' fill='none' stroke='%231C2833' stroke-width='0.3'/%3E%3C/svg%3E");
    background-size: 80px 80px;
}

.provocateur__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(232, 92, 73, 0.06) 0%, transparent 70%);
    pointer-events: none;
}

.provocateur__content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--space-md);
}

.provocateur__symbol {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    margin: 0 auto var(--space-lg);
    border: 1px solid rgba(232, 92, 73, 0.3);
    border-radius: 50%;
    color: var(--vision);
    animation: symbolPulse 3s ease-in-out infinite;
}

.provocateur__symbol svg {
    width: 28px;
    height: 28px;
}

.provocateur__question {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--shadow);
    line-height: 1.3;
    margin-bottom: var(--space-md);
}

.provocateur__answer {
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--silhouette);
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.8;
}

.provocateur__line {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, var(--vision), var(--insight));
    margin: var(--space-lg) auto 0;
    opacity: 0.6;
}

/* ============================================
   FOOTER
   ============================================ */
.footer {
    padding: var(--space-lg) 0;
    border-top: 1px solid rgba(28, 40, 51, 0.08);
    background: var(--light);
}

.footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
}

.footer__copy {
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--silhouette);
}

.footer__copy span {
    color: var(--vision);
}

.footer__links {
    display: flex;
    gap: var(--space-md);
    list-style: none;
}

.footer__links a {
    font-size: 0.8rem;
    color: var(--silhouette);
    transition: color var(--duration-fast) var(--ease-smooth);
}

.footer__links a:hover {
    color: var(--shadow);
}

/* ============================================
   ANIMATIONS
   ============================================ */
@keyframes fadeSlideUp {
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeIn {
    to {
        opacity: 1;
    }
}

@keyframes portalPulse {

    0%,
    100% {
        opacity: 0.3;
        transform: translate(-50%, -50%) scale(1);
    }

    50% {
        opacity: 0.7;
        transform: translate(-50%, -50%) scale(1.03);
    }
}

@keyframes portalSpin {
    from {
        transform: translate(-50%, -50%) rotate(0deg);
    }

    to {
        transform: translate(-50%, -50%) rotate(360deg);
    }
}

@keyframes portalSpinReverse {
    from {
        transform: translate(-50%, -50%) rotate(360deg);
    }

    to {
        transform: translate(-50%, -50%) rotate(0deg);
    }
}

@keyframes prismGlow {

    0%,
    100% {
        opacity: 0.5;
        transform: scale(1);
    }

    50% {
        opacity: 0.9;
        transform: scale(1.05);
    }
}

@keyframes columnReveal {
    from {
        opacity: 0;
        transform: scaleY(0);
        transform-origin: bottom;
    }

    to {
        opacity: 0.08;
        transform: scaleY(1);
        transform-origin: bottom;
    }
}

@keyframes scrollPulse {

    0%,
    100% {
        opacity: 0.4;
        transform: scaleY(1);
    }

    50% {
        opacity: 1;
        transform: scaleY(1.3);
    }
}

@keyframes symbolPulse {

    0%,
    100% {
        box-shadow: 0 0 0 0 rgba(232, 92, 73, 0.2);
    }

    50% {
        box-shadow: 0 0 0 15px rgba(232, 92, 73, 0);
    }
}

/* ============================================
   SCROLL REVEAL BASE
   ============================================ */
.reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s var(--ease-smooth), transform 0.7s var(--ease-smooth);
}

.reveal.visible {
    opacity: 1;
    transform: translateY(0);
}

/* ============================================
   CONTACT SECTION
   ============================================ */
.contact-section {
    padding: var(--space-xl) 0;
    background-color: #f0f2f5;
    position: relative;
}

.contact-section__title {
    font-size: 4rem;
    font-weight: 800;
    color: var(--shadow);
    margin-bottom: var(--space-xl);
}

.contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-xl);
    align-items: start;
}

.contact-form-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
}

.contact-card {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    padding: var(--space-md);
}

.contact-card--form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    min-height: 350px;
}

.contact-textarea {
    flex: 1;
    width: 100%;
    border: none;
    resize: none;
    font-family: var(--font-primary);
    font-size: 1.1rem;
    color: var(--shadow);
    padding: var(--space-sm);
    background: transparent;
    outline: none;
}

.contact-textarea::placeholder {
    color: rgba(28, 40, 51, 0.4);
}

.contact-btn {
    align-self: flex-start;
    padding: 0.75rem 4rem;
    background: transparent;
    border: 2px solid var(--vision);
    border-radius: 8px;
    color: var(--vision);
    font-weight: 700;
    font-size: 1.2rem;
    transition: all var(--duration-base) var(--ease-smooth);
}

.contact-btn:hover {
    background: var(--vision);
    color: var(--light);
}

.contact-alt {
    font-size: 0.95rem;
    color: var(--silhouette);
    line-height: 1.5;
    max-width: 300px;
}

.contact-alt a {
    color: var(--vision);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 4px;
}

.contact-calendly-wrapper {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 40px rgba(0, 0, 0, 0.08);
    overflow: hidden;
}

/* Adjust for mobile */
@media (max-width: 1024px) {
    .contact-grid {
        grid-template-columns: 1fr;
    }

    .contact-section__title {
        font-size: 3rem;
        margin-bottom: var(--space-lg);
    }
}
